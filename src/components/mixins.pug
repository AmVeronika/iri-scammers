// CARDS
mixin cardSign(title, list, iconName, alt)
    .card-sign(class=`card-sign--${iconName}`)
        p.card-sign__title !{title}
        if list && list.length
            ui.card-sign__list
                each el in list
                    li.card-sign__item !{el}
        - var className = `card-sign__icon--${iconName}`
        img.card-sign__icon(class=className src=`assets/images/${iconName}.png` alt=alt)

// DECORS

mixin scammersBg(className)
    .scammers-bg(class=className)
        .scammers-bg__anim
            .scammers-bg__element
